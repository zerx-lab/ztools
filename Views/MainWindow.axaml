<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ztools.ViewModels"
        xmlns:views="using:ztools.Views"
        xmlns:m="using:ztools.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="ztools.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ZTools"
        Icon="/Assets/ztools_256.png"
        Width="900" Height="640"
        MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        Background="#0D1117"
        FontFamily="Inter,Segoe UI,system-ui,sans-serif">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>

        <!-- ── Nav button ─────────────────────────────────────────────────── -->
        <Style Selector="Button.NavBtn">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalAlignment"        Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment"   Value="Stretch"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="CornerRadius"    Value="0"/>
            <Setter Property="Margin"          Value="0,1,0,1"/>
        </Style>
        <Style Selector="Button.NavBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1C2128"/>
        </Style>
        <Style Selector="Button.NavBtn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#21262D"/>
        </Style>

        <!-- ── Chrome buttons ────────────────────────────────────────────── -->
        <Style Selector="Button.ChromeBtn">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="46"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="CornerRadius"    Value="0"/>
        </Style>
        <Style Selector="Button.ChromeBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#333C47"/>
        </Style>
        <Style Selector="Button.ChromeBtn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#252D38"/>
        </Style>
        <Style Selector="Button.ChromeClose:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#C42B2B"/>
        </Style>
        <Style Selector="Button.ChromeClose:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#9E2222"/>
        </Style>
        <Style Selector="Button.ChromeClose:pointerover Path">
            <Setter Property="Stroke" Value="White"/>
        </Style>

        <!-- ── IconBtn (sidebar toggle) ──────────────────────────────────── -->
        <Style Selector="Button.IconBtn">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="36"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
        </Style>
        <Style Selector="Button.IconBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1C2128"/>
        </Style>

        <!-- ── Status dot ────────────────────────────────────────────────── -->
        <Style Selector="Border.StatusDot">
            <Setter Property="Width"        Value="6"/>
            <Setter Property="Height"       Value="6"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Background"   Value="#00D4FF"/>
        </Style>

    </Window.Styles>

    <!-- ═══════════════════════════════════════════════════════════════════════
         ROOT GRID — resize grips on all edges/corners (ZIndex=100/101)
         ═══════════════════════════════════════════════════════════════════════ -->
    <Grid>

        <!-- Resize grips -->
        <Border x:Name="ResizeTop"         Height="6"  VerticalAlignment="Top"    Background="Transparent" Cursor="SizeNorthSouth"   ZIndex="100"/>
        <Border x:Name="ResizeBottom"      Height="6"  VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNorthSouth"   ZIndex="100"/>
        <Border x:Name="ResizeLeft"        Width="6"   HorizontalAlignment="Left"  Background="Transparent" Cursor="SizeWestEast"    ZIndex="100"/>
        <Border x:Name="ResizeRight"       Width="6"   HorizontalAlignment="Right" Background="Transparent" Cursor="SizeWestEast"    ZIndex="100"/>
        <Border x:Name="ResizeTopLeft"     Width="12"  Height="12" HorizontalAlignment="Left"  VerticalAlignment="Top"    Background="Transparent" Cursor="TopLeftCorner"     ZIndex="101"/>
        <Border x:Name="ResizeTopRight"    Width="12"  Height="12" HorizontalAlignment="Right" VerticalAlignment="Top"    Background="Transparent" Cursor="TopRightCorner"    ZIndex="101"/>
        <Border x:Name="ResizeBottomLeft"  Width="12"  Height="12" HorizontalAlignment="Left"  VerticalAlignment="Bottom" Background="Transparent" Cursor="BottomLeftCorner"  ZIndex="101"/>
        <Border x:Name="ResizeBottomRight" Width="12"  Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" Cursor="BottomRightCorner" ZIndex="101"/>

        <!-- Main chrome container -->
        <Border BorderBrush="#30363D" BorderThickness="1" CornerRadius="10"
                Background="#0D1117"
                BoxShadow="0 8 56 0 #BB000000, 0 2 12 0 #66000000"
                ZIndex="0">

            <Grid RowDefinitions="40,*,28">

                <!-- ══════════════════════════════════════════════════════════
                     ROW 0 — CUSTOM TITLE BAR
                     ══════════════════════════════════════════════════════════ -->
                <Border Grid.Row="0"
                        Background="#161B22"
                        BorderBrush="#30363D"
                        BorderThickness="0,0,0,1"
                        CornerRadius="10,10,0,0">
                    <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch">

                        <!-- Left: logo mark + title -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="8"
                                    Margin="14,0,0,0">
                            <Border Width="22" Height="22" CornerRadius="6"
                                    Background="#1C2128"
                                    BorderBrush="#30363D" BorderThickness="1">
                                <Border Width="10" Height="10" CornerRadius="3"
                                        Background="#00D4FF" Opacity="0.95"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="ZTools"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#E6EDF3"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Center: drag region -->
                        <Border Grid.Column="1"
                                x:Name="TitleBarDragRegion"
                                Background="Transparent"
                                IsHitTestVisible="True"/>

                        <!-- Right: min / max / close -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch">

                            <Button x:Name="BtnMinimize" Classes="ChromeBtn" ToolTip.Tip="Minimize">
                                <Viewbox Width="12" Height="12" Stretch="Uniform">
                                    <Canvas Width="24" Height="24">
                                        <Rectangle Canvas.Left="3" Canvas.Top="11"
                                                   Width="18" Height="2"
                                                   Fill="#8B949E" RadiusX="1" RadiusY="1"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <Button x:Name="BtnMaximize" Classes="ChromeBtn" ToolTip.Tip="Maximize / Restore">
                                <Viewbox Width="12" Height="12" Stretch="Uniform">
                                    <Canvas Width="24" Height="24">
                                        <Rectangle Canvas.Left="3" Canvas.Top="3"
                                                   Width="18" Height="18"
                                                   Stroke="#8B949E" StrokeThickness="2"
                                                   Fill="Transparent" RadiusX="1" RadiusY="1"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <Button x:Name="BtnClose" Classes="ChromeBtn ChromeClose"
                                    ToolTip.Tip="Close"
                                    CornerRadius="0,10,0,0">
                                <Viewbox Width="12" Height="12" Stretch="Uniform">
                                    <Canvas Width="24" Height="24">
                                        <Path Stroke="#8B949E" StrokeThickness="2"
                                              StrokeLineCap="Round"
                                              Data="M4,4 L20,20 M20,4 L4,20"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════════════════════
                     ROW 1 — SIDEBAR + MAIN CONTENT
                     ══════════════════════════════════════════════════════════ -->
                <Grid Grid.Row="1" ColumnDefinitions="Auto,*">

                    <!-- ── LEFT SIDEBAR ──────────────────────────────────── -->
                    <Grid Grid.Column="0" ColumnDefinitions="*,5">

                        <Border Grid.Column="0"
                                x:Name="Sidebar"
                                Width="{Binding SidebarWidth}"
                                MinWidth="52"
                                MaxWidth="320"
                                Background="#161B22"
                                ClipToBounds="True">

                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Width"
                                                      Duration="0:0:0.2"
                                                      Easing="CubicEaseInOut"/>
                                </Transitions>
                            </Border.Transitions>

                            <Grid RowDefinitions="Auto,*,Auto">

                                <!-- Section label — only when expanded -->
                                <TextBlock Grid.Row="0"
                                           Text="NAVIGATION"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="#484F58"
                                           LetterSpacing="1.5"
                                           Margin="16,16,8,8"
                                           IsVisible="{Binding IsSidebarExpanded}"/>

                                <!-- Nav items -->
                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Hidden"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding NavItems}"
                                                  Margin="0,4,0,4">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="m:NavItem">
                                                <Button Classes="NavBtn"
                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectNavCommand}"
                                                        CommandParameter="{Binding}"
                                                        Padding="0"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Stretch">
                                                    <Grid HorizontalAlignment="Stretch">

                                                        <!-- Active accent left-bar -->
                                                        <Border Width="3" CornerRadius="0,2,2,0"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Stretch"
                                                                IsVisible="{Binding IsSelected}">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                                                    <GradientStop Color="#00D4FF" Offset="0"/>
                                                                    <GradientStop Color="#0EA5E9" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>

                                                        <!-- Active background tint -->
                                                        <Border Margin="4,0"
                                                                CornerRadius="8"
                                                                IsVisible="{Binding IsSelected}">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="#00D4FF" Opacity="0.07"/>
                                                            </Border.Background>
                                                        </Border>

                                                        <!-- Icon + label row -->
                                                        <StackPanel Orientation="Horizontal"
                                                                    VerticalAlignment="Center"
                                                                    Spacing="12"
                                                                    Margin="16,0,10,0">
                                                            <Viewbox Width="17" Height="17" Stretch="Uniform">
                                                                <Canvas Width="24" Height="24">
                                                                    <Path Data="{Binding IconPath}"
                                                                          Canvas.Left="0" Canvas.Top="0">
                                                                        <Path.Fill>
                                                                            <SolidColorBrush Color="#8B949E"/>
                                                                        </Path.Fill>
                                                                    </Path>
                                                                </Canvas>
                                                            </Viewbox>

                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="12"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="#C9D1D9"
                                                                       IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsSidebarExpanded}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- Bottom: collapse / expand toggle button -->
                                <Border Grid.Row="2"
                                        BorderBrush="#21262D"
                                        BorderThickness="0,1,0,0"
                                        Padding="0,6,0,10">
                                    <Button Classes="NavBtn"
                                            Command="{Binding ToggleSidebarCommand}"
                                            Height="36"
                                            ToolTip.Tip="Toggle sidebar"
                                            Padding="0"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Spacing="12"
                                                    Margin="16,0,10,0">
                                            <Border Width="17" Height="17">
                                                <Viewbox Width="17" Height="17" Stretch="Uniform">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Stroke="#8B949E"
                                                              StrokeThickness="2.2"
                                                              StrokeLineCap="Round"
                                                              Fill="Transparent"
                                                              Data="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CollapseArrowData}"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <TextBlock Text="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).L[Nav.Collapse]}"
                                                       FontSize="12"
                                                       Foreground="#8B949E"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsSidebarExpanded}"/>
                                        </StackPanel>
                                    </Button>
                                </Border>

                            </Grid>
                        </Border>

                        <!-- Drag splitter -->
                        <Grid Grid.Column="1" RowDefinitions="*">
                            <Border Width="1"
                                    HorizontalAlignment="Left"
                                    Background="#30363D"/>
                            <Border x:Name="SidebarSplitter"
                                    Background="Transparent"
                                    Cursor="SizeWestEast"
                                    Width="5"
                                    HorizontalAlignment="Stretch"/>
                        </Grid>

                    </Grid>

                    <!-- ── MAIN CONTENT ──────────────────────────────────── -->
                    <ContentControl Grid.Column="1"
                                    Content="{Binding CurrentPageContent}">
                        <ContentControl.DataTemplates>
                            <DataTemplate DataType="vm:WindowManagerViewModel">
                                <views:WindowManagerView DataContext="{Binding}"/>
                            </DataTemplate>
                            <DataTemplate DataType="vm:SettingsViewModel">
                                <views:SettingsView DataContext="{Binding}"/>
                            </DataTemplate>
                        </ContentControl.DataTemplates>
                    </ContentControl>

                </Grid>

                <!-- ══════════════════════════════════════════════════════════
                     ROW 2 — STATUS BAR
                     ══════════════════════════════════════════════════════════ -->
                <Border Grid.Row="2"
                        Background="#161B22"
                        BorderBrush="#30363D" BorderThickness="0,1,0,0"
                        CornerRadius="0,0,10,10"
                        Padding="16,0">
                    <Grid ColumnDefinitions="*,Auto">

                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="7">
                            <Border Classes="StatusDot" VerticalAlignment="Center"/>
                            <TextBlock FontSize="11" VerticalAlignment="Center">
                                <Run Text="{Binding AppVersion}"
                                     Foreground="#8B949E"
                                     FontWeight="Medium"/>
                                <Run Text="  —  " Foreground="#484F58"/>
                                <Run Text="{Binding L[Status.Suite]}" Foreground="#484F58"/>
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding L[Status.WindowManager]}"
                                   FontSize="11" Foreground="#484F58"
                                   VerticalAlignment="Center"/>

                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>

</Window>
