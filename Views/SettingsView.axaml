<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ztools.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="ztools.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="Transparent">

    <UserControl.Styles>

        <!-- ── Section label ────────────────────────────────────────────────── -->
        <Style Selector="TextBlock.SectionLabel">
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="#484F58"/>
            <Setter Property="LetterSpacing" Value="1.5"/>
            <Setter Property="Margin"       Value="0,0,0,16"/>
        </Style>

        <!-- ── Setting row label ────────────────────────────────────────────── -->
        <Style Selector="TextBlock.RowLabel">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
        </Style>

        <!-- ── Setting row description ──────────────────────────────────────── -->
        <Style Selector="TextBlock.RowDesc">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="Margin"     Value="0,3,0,0"/>
        </Style>

        <!-- ── Toggle ToggleButton (pill switch) ────────────────────────────── -->
        <Style Selector="ToggleButton.PillSwitch">
            <Setter Property="Width"            Value="44"/>
            <Setter Property="Height"           Value="24"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Background"       Value="#30363D"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="CornerRadius"     Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="TrackBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Width="44" Height="24">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.18" Easing="CubicEaseInOut"/>
                            </Transitions>
                        </Border.Transitions>
                        <Canvas Width="44" Height="24" ClipToBounds="False">
                            <Border x:Name="Thumb"
                                    Width="18" Height="18"
                                    CornerRadius="9"
                                    Background="White"
                                    Canvas.Left="3"
                                    Canvas.Top="3">
                                <Border.BoxShadow>0 1 4 0 #44000000</Border.BoxShadow>
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Canvas.Left" Duration="0:0:0.18" Easing="CubicEaseInOut"/>
                                    </Transitions>
                                </Border.Transitions>
                            </Border>
                        </Canvas>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.PillSwitch:checked /template/ Border#TrackBorder">
            <Setter Property="Background" Value="#00D4FF"/>
        </Style>
        <Style Selector="ToggleButton.PillSwitch:checked /template/ Border#Thumb">
            <Setter Property="Canvas.Left" Value="23"/>
        </Style>
        <Style Selector="ToggleButton.PillSwitch:pointerover /template/ Border#TrackBorder">
            <Setter Property="Opacity" Value="0.88"/>
        </Style>



        <!-- ── Info row ──────────────────────────────────────────────────────── -->
        <Style Selector="TextBlock.InfoKey">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="Margin"     Value="0,0,0,10"/>
        </Style>
        <Style Selector="TextBlock.InfoVal">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="Margin"     Value="0,0,0,10"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <!-- ── Language ComboBox ─────────────────────────────────────────────── -->
        <Style Selector="ComboBox.LangCombo">
            <Setter Property="Background"      Value="#1C2128"/>
            <Setter Property="BorderBrush"     Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#E6EDF3"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Width"           Value="240"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="10,0,8,0"/>
        </Style>

        <!-- ── Copy button ───────────────────────────────────────────────────── -->
        <Style Selector="Button.CopyBtn">
            <Setter Property="Background"      Value="#1C2128"/>
            <Setter Property="BorderBrush"     Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#C9D1D9"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style Selector="Button.CopyBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background"  Value="#21262D"/>
        </Style>
        <Style Selector="Button.CopyBtn:pressed /template/ ContentPresenter">
            <Setter Property="Background"  Value="#30363D"/>
        </Style>

    </UserControl.Styles>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SCROLL WRAPPER
         ═══════════════════════════════════════════════════════════════════════ -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <StackPanel Margin="32,28,32,32" Spacing="0">

            <!-- ── Page header ──────────────────────────────────────────────── -->
            <StackPanel Margin="0,0,0,28">
                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,6">
                    <TextBlock Text="{Binding L[Settings.Title]}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#E6EDF3"/>
                </StackPanel>
                <TextBlock Text="{Binding L[Settings.Subtitle]}"
                           FontSize="13" Foreground="#8B949E"/>
            </StackPanel>

            <!-- ══════════════════════════════════════════════════════════════
                 LANGUAGE SECTION
                 ══════════════════════════════════════════════════════════════ -->
            <TextBlock Text="{Binding L[Settings.Section.Language]}"
                       Classes="SectionLabel"/>

            <Border Background="#161B22"
                    BorderBrush="#30363D" BorderThickness="1"
                    CornerRadius="10" Padding="24"
                    Margin="0,0,0,16">
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <!-- Left: label + desc -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="0">
                        <TextBlock Text="{Binding L[Settings.Language.Label]}"
                                   Classes="RowLabel"/>
                        <TextBlock Text="{Binding L[Settings.Language.Desc]}"
                                   Classes="RowDesc"/>
                    </StackPanel>

                    <!-- Right: ComboBox -->
                    <ComboBox Grid.Column="1"
                              Classes="LangCombo"
                              ItemsSource="{Binding AvailableLocales}"
                              SelectedItem="{Binding SelectedLanguageOption}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:LanguageOption">
                                <TextBlock Text="{Binding DisplayName}"
                                           FontSize="13"
                                           Foreground="#E6EDF3"
                                           Padding="0,4"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </Border>



            <!-- ══════════════════════════════════════════════════════════════
                 GENERAL SECTION
                 ══════════════════════════════════════════════════════════════ -->
            <TextBlock Text="{Binding L[Settings.Section.General]}"
                       Classes="SectionLabel"
                       Margin="0,8,0,16"/>

            <Border Background="#161B22"
                    BorderBrush="#30363D" BorderThickness="1"
                    CornerRadius="10"
                    Margin="0,0,0,16">

                <!-- Start with Windows row -->
                <StackPanel>
                    <Grid ColumnDefinitions="*,Auto"
                          Margin="24,20,24,20"
                          VerticalAlignment="Center">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="0">
                            <TextBlock Text="{Binding L[Settings.StartWithWindows.Label]}"
                                       Classes="RowLabel"/>
                            <TextBlock Text="{Binding L[Settings.StartWithWindows.Desc]}"
                                       Classes="RowDesc"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      Classes="PillSwitch"
                                      IsChecked="{Binding StartWithWindows}"/>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="#21262D" Margin="24,0"/>

                    <!-- Silent start row -->
                    <Grid ColumnDefinitions="*,Auto"
                          Margin="24,20,24,20"
                          VerticalAlignment="Center">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="0">
                            <TextBlock Text="{Binding L[Settings.SilentStart.Label]}"
                                       Classes="RowLabel"/>
                            <TextBlock Text="{Binding L[Settings.SilentStart.Desc]}"
                                       Classes="RowDesc"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      Classes="PillSwitch"
                                      IsChecked="{Binding SilentStart}"/>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="#21262D" Margin="24,0"/>

                    <!-- Minimize to tray row -->
                    <Grid ColumnDefinitions="*,Auto"
                          Margin="24,20,24,20"
                          VerticalAlignment="Center">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="0">
                            <TextBlock Text="{Binding L[Settings.MinimizeToTray.Label]}"
                                       Classes="RowLabel"/>
                            <TextBlock Text="{Binding L[Settings.MinimizeToTray.Desc]}"
                                       Classes="RowDesc"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      Classes="PillSwitch"
                                      IsChecked="{Binding MinimizeToTray}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════
                 ABOUT SECTION
                 ══════════════════════════════════════════════════════════════ -->
            <TextBlock Text="{Binding L[Settings.Section.About]}"
                       Classes="SectionLabel"
                       Margin="0,8,0,16"/>

            <Border Background="#161B22"
                    BorderBrush="#30363D" BorderThickness="1"
                    CornerRadius="10" Padding="24"
                    Margin="0,0,0,16">
                <StackPanel Spacing="0">

                    <!-- App identity row -->
                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,24">
                        <!-- Icon -->
                        <Border Width="52" Height="52" CornerRadius="14"
                                Background="#1C2128"
                                BorderBrush="#30363D" BorderThickness="1">
                            <Border Width="24" Height="24" CornerRadius="7"
                                    Background="#00D4FF" Opacity="0.95"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>

                        <!-- Name + tagline -->
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="ZTools"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="#E6EDF3"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Border Background="#1C2128"
                                        BorderBrush="#30363D" BorderThickness="1"
                                        CornerRadius="4" Padding="7,2">
                                    <TextBlock FontSize="10" Foreground="#00D4FF"
                                               FontWeight="Medium">
                                        <Run Text="v"/>
                                        <Run Text="{Binding AppVersion}"/>
                                    </TextBlock>
                                </Border>
                                <Border Background="#1C2128"
                                        BorderBrush="#30363D" BorderThickness="1"
                                        CornerRadius="4" Padding="7,2">
                                    <TextBlock Text="Windows" FontSize="10"
                                               Foreground="#8B949E" FontWeight="Medium"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Height="1" Background="#21262D" Margin="0,0,0,20"/>

                    <!-- Info grid -->
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">

                        <!-- Version -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{Binding L[Settings.About.Version]}"
                                   Classes="InfoKey"
                                   Width="100"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding AppVersion}"
                                   Classes="InfoVal"/>

                        <!-- Build -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="{Binding L[Settings.About.Build]}"
                                   Classes="InfoKey"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding BuildDate}"
                                   Classes="InfoVal"/>

                        <!-- Platform -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{Binding L[Settings.About.Platform]}"
                                   Classes="InfoKey"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding Platform}"
                                   Classes="InfoVal"/>

                        <!-- Runtime -->
                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Text="{Binding L[Settings.About.Runtime]}"
                                   Classes="InfoKey"/>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding Runtime}"
                                   Classes="InfoVal"
                                   TextWrapping="Wrap"/>

                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="#21262D" Margin="0,4,0,20"/>

                    <!-- Copy version button -->
                    <Button Classes="CopyBtn"
                            Content="{Binding CopyBtnText}"
                            Command="{Binding CopyVersionInfoCommand}"
                            HorizontalAlignment="Left"/>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
