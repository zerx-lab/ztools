<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ztools.ViewModels"
             xmlns:m="using:ztools.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="ztools.Views.DevCleanerView"
             x:DataType="vm:DevCleanerViewModel"
             x:Name="RootView"
             Background="Transparent">

    <UserControl.Styles>

        <!-- ── Section label ────────────────────────────────────────────────── -->
        <Style Selector="TextBlock.SectionLabel">
            <Setter Property="FontSize"      Value="10"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Foreground"    Value="#484F58"/>
            <Setter Property="LetterSpacing" Value="1.5"/>
            <Setter Property="Margin"        Value="0,0,0,16"/>
        </Style>

        <Style Selector="TextBlock.RowLabel">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
        </Style>

        <Style Selector="TextBlock.RowDesc">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="Margin"     Value="0,3,0,0"/>
        </Style>

        <!-- ── Primary button (accent gradient) ─────────────────────────────── -->
        <Style Selector="Button.Primary">
            <Setter Property="Background"      Value="{StaticResource BrushAccentGradient}"/>
            <Setter Property="Foreground"      Value="#0D1117"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="18,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style Selector="Button.Primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BrushAccentGradient}"/>
            <Setter Property="Opacity"    Value="0.88"/>
        </Style>
        <Style Selector="Button.Primary:disabled">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>

        <!-- ── Ghost button ─────────────────────────────────────────────────── -->
        <Style Selector="Button.Ghost">
            <Setter Property="Background"      Value="#1C2128"/>
            <Setter Property="Foreground"      Value="#E6EDF3"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="14,9"/>
            <Setter Property="BorderBrush"     Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style Selector="Button.Ghost:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#21262D"/>
        </Style>

        <!-- ── Danger button ────────────────────────────────────────────────── -->
        <Style Selector="Button.Danger">
            <Setter Property="Background"      Value="#DA3633"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="18,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style Selector="Button.Danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F85149"/>
        </Style>
        <Style Selector="Button.Danger:disabled">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>

        <!-- ── Small inline clean button ────────────────────────────────────── -->
        <Style Selector="Button.RowClean">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#F85149"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="BorderBrush"     Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style Selector="Button.RowClean:pointerover /template/ ContentPresenter">
            <Setter Property="Background"  Value="#2D1617"/>
        </Style>

        <!-- ── Remove (×) icon button ───────────────────────────────────────── -->
        <Style Selector="Button.RemoveBtn">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#8B949E"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Padding"         Value="6,2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style Selector="Button.RemoveBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#21262D"/>
        </Style>
        <Style Selector="Button.RemoveBtn:pointerover">
            <Setter Property="Foreground" Value="#F85149"/>
        </Style>

        <!-- ── CheckBox compact ─────────────────────────────────────────────── -->
        <Style Selector="CheckBox">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Padding"  Value="0"/>
        </Style>
        <!-- ── Search box ────────────────────────────────────────────── -->
        <Style Selector="TextBox.Search">
            <Setter Property="Background"      Value="#0D1117"/>
            <Setter Property="BorderBrush"     Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#E6EDF3"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="FontSize"        Value="12.5"/>
            <Setter Property="Padding"         Value="12,7"/>
            <Setter Property="MinHeight"       Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.Search:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background"  Value="#0D1117"/>
            <Setter Property="BorderBrush" Value="#484F58"/>
        </Style>
        <Style Selector="TextBox.Search:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background"  Value="#0D1117"/>
            <Setter Property="BorderBrush" Value="#00D4FF"/>
        </Style>

        <!-- ── Filter chip ────────────────────────────────────────────── -->
        <Style Selector="Button.Chip">
            <Setter Property="Background"      Value="#1C2128"/>
            <Setter Property="BorderBrush"     Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="14"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="Margin"          Value="0,0,8,6"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style Selector="Button.Chip TextBlock">
            <Setter Property="Foreground" Value="#8B949E"/>
        </Style>
        <Style Selector="Button.Chip:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#21262D"/>
        </Style>
        <Style Selector="Button.Chip.active">
            <Setter Property="Background"  Value="#0D2232"/>
            <Setter Property="BorderBrush" Value="#1C4A6E"/>
        </Style>
        <Style Selector="Button.Chip.active TextBlock">
            <Setter Property="Foreground" Value="#00D4FF"/>
        </Style>
        <Style Selector="Button.Chip.active:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0D2232"/>
        </Style>
        <Style Selector="Border.ChipCount">
            <Setter Property="Background"   Value="#30363D"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding"      Value="6,1"/>
            <Setter Property="MinWidth"     Value="18"/>
        </Style>
        <Style Selector="Button.Chip.active Border.ChipCount">
            <Setter Property="Background" Value="#1C4A6E"/>
        </Style>

        <!-- ── Group header button ─────────────────────────────────────── -->
        <Style Selector="Button.GroupHeader">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius"    Value="0"/>
            <Setter Property="Padding"         Value="8,11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalAlignment"        Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.GroupHeader:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </UserControl.Styles>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SCROLL WRAPPER
         ═══════════════════════════════════════════════════════════════════════ -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <StackPanel Margin="32,28,32,32" Spacing="0">

            <!-- ── Page header ──────────────────────────────────────────────── -->
            <StackPanel Margin="0,0,0,28">
                <TextBlock Text="{Binding L[Cleaner.Title]}"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#E6EDF3"
                           Margin="0,0,0,6"/>
                <TextBlock Text="{Binding L[Cleaner.Subtitle]}"
                           FontSize="13" Foreground="#8B949E"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- ══════════════════════════════════════════════════════════════
                 SCAN PATHS
                 ══════════════════════════════════════════════════════════════ -->
            <TextBlock Text="{Binding L[Cleaner.Section.Paths]}"
                       Classes="SectionLabel"/>

            <Border Background="#161B22"
                    BorderBrush="#30363D" BorderThickness="1"
                    CornerRadius="10"
                    Margin="0,0,0,16">
                <StackPanel>

                    <!-- Empty hint -->
                    <TextBlock Text="{Binding L[Cleaner.Paths.Empty]}"
                               IsVisible="{Binding !HasPaths}"
                               FontSize="12" Foreground="#484F58"
                               Margin="24,18,24,0"/>

                    <!-- Path rows -->
                    <ItemsControl ItemsSource="{Binding ScanPaths}"
                                  Margin="12,10,12,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      Margin="12,6"
                                      VerticalAlignment="Center">
                                    <!-- folder icon -->
                                    <Viewbox Grid.Column="0" Width="15" Height="15"
                                             Margin="0,0,10,0" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <Path Fill="#8B949E"
                                                  Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding}"
                                               FontSize="13" Foreground="#E6EDF3"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="2"
                                            Classes="RemoveBtn"
                                            Content="✕"
                                            Command="{Binding #RootView.((vm:DevCleanerViewModel)DataContext).RemovePathCommand}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Action row -->
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                          Margin="24,16,24,20">
                        <Button Grid.Column="0"
                                Classes="Ghost"
                                Click="OnAddFolderClick">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="+" FontSize="14" FontWeight="Bold"
                                           Foreground="#00D4FF" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding L[Cleaner.AddFolder]}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2"
                                Classes="Primary"
                                Content="{Binding L[Cleaner.Scan]}"
                                Command="{Binding ScanCommand}"
                                IsEnabled="{Binding HasPaths}"
                                IsVisible="{Binding !IsScanning}"/>
                        <Button Grid.Column="3"
                                Classes="Danger"
                                Content="{Binding L[Cleaner.Stop]}"
                                Command="{Binding StopScanCommand}"
                                IsVisible="{Binding IsScanning}"/>
                    </Grid>

                    <!-- Scan progress -->
                    <StackPanel IsVisible="{Binding IsScanning}"
                                Margin="24,0,24,18" Spacing="8">
                        <ProgressBar IsIndeterminate="True"
                                     Height="3" CornerRadius="2"
                                     Foreground="{StaticResource BrushAccentPrimary}"
                                     Background="#21262D"/>
                        <TextBlock Text="{Binding ScanStatus}"
                                   FontSize="11" Foreground="#8B949E"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════
                 RESULTS
                 ══════════════════════════════════════════════════════════════ -->
            <TextBlock Text="{Binding L[Cleaner.Section.Results]}"
                       Classes="SectionLabel"
                       Margin="0,8,0,16"/>

            <Border Background="#161B22"
                    BorderBrush="#30363D" BorderThickness="1"
                    CornerRadius="10"
                    Margin="0,0,0,16">
                <StackPanel>

                    <!-- Toolbar: search + select-all + clean selected -->
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="16,14,16,0">
                        <TextBox Grid.Column="0"
                                 Classes="Search"
                                 MaxWidth="340"
                                 HorizontalAlignment="Left"
                                 PlaceholderText="{Binding L[Cleaner.Search]}"
                                 Text="{Binding FilterText}">
                            <TextBox.InnerLeftContent>
                                <Viewbox Width="14" Height="14" Margin="10,0,2,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#484F58"
                                              Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"/>
                                    </Canvas>
                                </Viewbox>
                            </TextBox.InnerLeftContent>
                        </TextBox>
                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding IsAllSelected}"
                                  IsEnabled="{Binding HasVisible}"
                                  VerticalAlignment="Center"
                                  Margin="16,0,8,0"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding L[Cleaner.SelectAll]}"
                                   FontSize="12" Foreground="#8B949E"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="3"
                                Classes="Danger"
                                Margin="16,0,0,0"
                                Command="{Binding CleanSelectedCommand}"
                                IsEnabled="{Binding HasSelection}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding L[Cleaner.CleanSelected]}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SelectedSummary}"
                                           FontSize="11" Opacity="0.85"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding HasSelection}"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Filter chips + summary -->
                    <Grid ColumnDefinitions="*,Auto" Margin="16,12,16,6">
                        <ItemsControl Grid.Column="0" ItemsSource="{Binding Chips}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="m:FilterChip">
                                    <Button Classes="Chip"
                                            Classes.active="{Binding IsActive}"
                                            Command="{Binding #RootView.((vm:DevCleanerViewModel)DataContext).SelectChipCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="12" FontWeight="Medium"
                                                       VerticalAlignment="Center"/>
                                            <Border Classes="ChipCount"
                                                    IsVisible="{Binding HasCount}">
                                                <TextBlock Text="{Binding Count}"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal" Spacing="6"
                                    Margin="12,0,0,6"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding ResultsSummary}"
                                       FontSize="12" Foreground="#8B949E"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ResultsSizeText}"
                                       FontSize="12.5" FontWeight="SemiBold"
                                       Foreground="#00D4FF"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="#21262D"/>

                    <!-- Empty state -->
                    <TextBlock Text="{Binding L[Cleaner.Results.Empty]}"
                               IsVisible="{Binding !HasResults}"
                               FontSize="12" Foreground="#484F58"
                               HorizontalAlignment="Center"
                               Margin="0,28,0,28"/>

                    <!-- No-match state -->
                    <Panel IsVisible="{Binding HasResults}">
                        <TextBlock Text="{Binding L[Cleaner.NoMatch]}"
                                   IsVisible="{Binding !HasVisible}"
                                   FontSize="12" Foreground="#484F58"
                                   HorizontalAlignment="Center"
                                   Margin="0,28,0,28"/>
                    </Panel>

                    <!-- Grouped results -->
                    <ItemsControl ItemsSource="{Binding Groups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="m:CleanGroup">
                                <StackPanel>

                                    <!-- Group header -->
                                    <Border Background="#11161D"
                                            BorderBrush="#21262D" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="Auto,*" Margin="16,0">
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsChecked}"
                                                      Margin="8,0,0,0"
                                                      VerticalAlignment="Center"/>
                                            <Button Grid.Column="1"
                                                    Classes="GroupHeader"
                                                    Command="{Binding #RootView.((vm:DevCleanerViewModel)DataContext).ToggleGroupCommand}"
                                                    CommandParameter="{Binding}">
                                                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto">
                                                    <!-- chevron -->
                                                    <Viewbox Grid.Column="0" Width="12" Height="12"
                                                             Margin="2,0,10,0" VerticalAlignment="Center">
                                                        <Canvas Width="24" Height="24">
                                                            <Path Fill="#8B949E"
                                                                  IsVisible="{Binding IsExpanded}"
                                                                  Data="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z"/>
                                                            <Path Fill="#8B949E"
                                                                  IsVisible="{Binding !IsExpanded}"
                                                                  Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"/>
                                                        </Canvas>
                                                    </Viewbox>
                                                    <!-- icon tile -->
                                                    <Border Grid.Column="1"
                                                            Width="26" Height="26"
                                                            CornerRadius="7"
                                                            Background="{Binding TileBrush}"
                                                            Margin="0,0,10,0"
                                                            VerticalAlignment="Center">
                                                        <Viewbox Width="14" Height="14">
                                                            <Canvas Width="24" Height="24">
                                                                <Path Fill="{Binding BadgeBrush}"
                                                                      Data="{Binding IconData}"/>
                                                            </Canvas>
                                                        </Viewbox>
                                                    </Border>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Label}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="#E6EDF3"
                                                               VerticalAlignment="Center"/>
                                                    <!-- count pill -->
                                                    <Border Grid.Column="3"
                                                            Background="#21262D"
                                                            CornerRadius="8" Padding="7,1"
                                                            Margin="8,0,0,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding CountText}"
                                                                   FontSize="10.5" FontWeight="SemiBold"
                                                                   Foreground="#8B949E"/>
                                                    </Border>
                                                    <!-- size -->
                                                    <TextBlock Grid.Column="5"
                                                               Text="{Binding SizeText}"
                                                               FontSize="12.5" FontWeight="SemiBold"
                                                               Foreground="#00D4FF"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <!-- Group items -->
                                    <ItemsControl ItemsSource="{Binding Items}"
                                                  IsVisible="{Binding IsExpanded}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="m:CleanItem">
                                                <Border BorderBrush="#21262D"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="46,8,24,8"
                                                        Opacity="{Binding RowOpacity}">
                                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                                          VerticalAlignment="Center">

                                                        <CheckBox Grid.Column="0"
                                                                  IsChecked="{Binding IsSelected}"
                                                                  IsEnabled="{Binding CanClean}"
                                                                  Margin="0,0,12,0"
                                                                  VerticalAlignment="Center"/>

                                                        <!-- Name + full path -->
                                                        <StackPanel Grid.Column="1"
                                                                    Margin="0,0,12,0"
                                                                    VerticalAlignment="Center"
                                                                    Spacing="2">
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontSize="13" FontWeight="Medium"
                                                                       Foreground="#E6EDF3"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding Path}"
                                                                       FontSize="11" Foreground="#484F58"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>

                                                        <!-- Size -->
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding SizeDisplay}"
                                                                   FontSize="12.5" FontWeight="SemiBold"
                                                                   Foreground="#00D4FF"
                                                                   MinWidth="76" TextAlignment="Right"
                                                                   Margin="0,0,16,0"
                                                                   VerticalAlignment="Center"/>

                                                        <!-- Action -->
                                                        <Panel Grid.Column="3" MinWidth="64">
                                                            <Button Classes="RowClean"
                                                                    Content="{Binding #RootView.((vm:DevCleanerViewModel)DataContext).L[Cleaner.Clean]}"
                                                                    Command="{Binding #RootView.((vm:DevCleanerViewModel)DataContext).CleanItemCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    IsVisible="{Binding CanClean}"
                                                                    HorizontalAlignment="Right"/>
                                                            <ProgressBar IsIndeterminate="True"
                                                                         IsVisible="{Binding IsCleaning}"
                                                                         Width="56" Height="3"
                                                                         Foreground="#F85149" Background="#21262D"
                                                                         VerticalAlignment="Center"
                                                                         HorizontalAlignment="Right"/>
                                                            <TextBlock Text="{Binding #RootView.((vm:DevCleanerViewModel)DataContext).L[Cleaner.Cleaned]}"
                                                                       IsVisible="{Binding IsCleaned}"
                                                                       FontSize="12" Foreground="#3FB950"
                                                                       VerticalAlignment="Center"
                                                                       HorizontalAlignment="Right"/>
                                                        </Panel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════
                 GLOBAL CACHES
                 ══════════════════════════════════════════════════════════════ -->
            <TextBlock Text="{Binding L[Cleaner.Section.Caches]}"
                       Classes="SectionLabel"
                       Margin="0,8,0,16"/>

            <Border Background="#161B22"
                    BorderBrush="#30363D" BorderThickness="1"
                    CornerRadius="10"
                    Margin="0,0,0,16">
                <StackPanel>

                    <TextBlock Text="{Binding L[Cleaner.Caches.Desc]}"
                               FontSize="11" Foreground="#8B949E"
                               Margin="24,16,24,8"
                               TextWrapping="Wrap"/>

                    <ItemsControl ItemsSource="{Binding GlobalCaches}"
                                  Margin="0,4,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="m:CleanItem">
                                <Border BorderBrush="#21262D"
                                        BorderThickness="0,1,0,0"
                                        Padding="24,10"
                                        Opacity="{Binding RowOpacity}">
                                    <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                                          VerticalAlignment="Center">

                                        <!-- Icon tile -->
                                        <Border Grid.Column="0"
                                                Width="28" Height="28"
                                                CornerRadius="8"
                                                Background="{Binding TileBrush}"
                                                Margin="0,0,12,0"
                                                VerticalAlignment="Center">
                                            <Viewbox Width="15" Height="15">
                                                <Canvas Width="24" Height="24">
                                                    <Path Fill="{Binding BadgeBrush}"
                                                          Data="{Binding IconData}"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Border>

                                        <!-- Category label -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding CategoryLabel}"
                                                   FontSize="12.5" FontWeight="Medium"
                                                   Foreground="#E6EDF3"
                                                   Width="110"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Path}"
                                                   FontSize="12" Foreground="#8B949E"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="12,0"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding SizeDisplay}"
                                                   FontSize="12.5" FontWeight="SemiBold"
                                                   Foreground="#00D4FF"
                                                   MinWidth="76" TextAlignment="Right"
                                                   Margin="0,0,16,0"
                                                   VerticalAlignment="Center"/>

                                        <Panel Grid.Column="4" MinWidth="64">
                                            <Button Classes="RowClean"
                                                    Content="{Binding #RootView.((vm:DevCleanerViewModel)DataContext).L[Cleaner.Clean]}"
                                                    Command="{Binding #RootView.((vm:DevCleanerViewModel)DataContext).CleanItemCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsVisible="{Binding CanClean}"
                                                    HorizontalAlignment="Right"/>
                                            <ProgressBar IsIndeterminate="True"
                                                         IsVisible="{Binding IsCleaning}"
                                                         Width="56" Height="3"
                                                         Foreground="#F85149" Background="#21262D"
                                                         VerticalAlignment="Center"
                                                         HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding #RootView.((vm:DevCleanerViewModel)DataContext).L[Cleaner.Cleaned]}"
                                                       IsVisible="{Binding IsCleaned}"
                                                       FontSize="12" Foreground="#3FB950"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                        </Panel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
